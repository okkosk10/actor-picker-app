{
  "name": "actor-picker-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron": "wait-on http://localhost:5173 && electron .",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "test": "node --test electron/services/**/*.test.cjs",
    "dist": "vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^24.13.3",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.actorpicker.app",
    "productName": "Actor Picker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": ".env", "to": ".env" }
    ],
    "npmRebuild": true,
    "win": {
      "target": "portable",
      "icon": "build/icon.ico",
      "sign": null,
      "signingHashAlgorithms": null
    }
  },
  "dependencies": {
    "antd": "^6.3.7",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "openai": "^6.37.0"
  }
}
